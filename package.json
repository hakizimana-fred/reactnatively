{
  "name": "reactnatively-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build --filter=@reactnatively/* && changeset publish",
    "playground": "pnpm --filter playground start"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@types/react": "^19.1.1",
    "@types/react-native": "^0.73.0",
    "turbo": "^2.1.3",
    "typescript": "^5.5.3",
    "prettier": "^3.3.3"
  },
  "packageManager": "pnpm@9.4.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.4.0"
  },
  "prettier": {
    "singleQuote": true,
    "semi": true,
    "tabWidth": 2,
    "trailingComma": "all",
    "printWidth": 100
  }
}
