{
  "name": "reactnatively-theme",
  "version": "4.0.0",
  "description": "Liquid Glass token engine and theme system for Reactnatively",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "reactnatively-utils": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0"
  },
  "devDependencies": {
    "@reactnatively/tsconfig": "workspace:*",
    "tsup": "^8.2.4",
    "typescript": "^5.5.3"
  },
  "keywords": [
    "react-native",
    "expo",
    "theme",
    "tokens",
    "design-system",
    "glass",
    "liquid-glass",
    "dark-mode",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hakizimana-fred/reactnatively.git",
    "directory": "packages/theme"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
