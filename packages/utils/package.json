{
  "name": "@reactnatively/utils",
  "version": "0.1.0",
  "description": "Shared utilities and TypeScript helpers for the Reactnatively framework",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0"
  },
  "devDependencies": {
    "@reactnatively/tsconfig": "workspace:*",
    "tsup": "^8.2.4",
    "typescript": "^5.5.3"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
