{
  "name": "@reactnatively/core",
  "version": "0.1.0",
  "description": "Liquid Glass component library — the complete Reactnatively UI system",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reactnatively/animations": "workspace:*",
    "@reactnatively/glass": "workspace:*",
    "@reactnatively/hooks": "workspace:*",
    "@reactnatively/primitives": "workspace:*",
    "@reactnatively/theme": "workspace:*",
    "@reactnatively/utils": "workspace:*"
  },
  "peerDependencies": {
    "expo-blur": ">=13.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "react-native-gesture-handler": ">=2.14.0",
    "react-native-linear-gradient": ">=2.8.0",
    "react-native-reanimated": ">=3.6.0"
  },
  "devDependencies": {
    "@reactnatively/tsconfig": "workspace:*",
    "@testing-library/react-native": "^12.5.1",
    "jest": "^29.7.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.3"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
