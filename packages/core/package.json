{
  "name": "reactnatively",
  "version": "4.0.0",
  "description": "Liquid Glass UI system for React Native & Expo — components, animations, theming",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./glass": {
      "types": "./dist/glass.d.ts",
      "import": "./dist/glass.mjs",
      "require": "./dist/glass.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.mjs",
      "require": "./dist/hooks.js"
    },
    "./animations": {
      "types": "./dist/animations.d.ts",
      "import": "./dist/animations.mjs",
      "require": "./dist/animations.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.mjs",
      "require": "./dist/theme.js"
    },
    "./primitives": {
      "types": "./dist/primitives.d.ts",
      "import": "./dist/primitives.mjs",
      "require": "./dist/primitives.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.mjs",
      "require": "./dist/utils.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "reactnatively-animations": "workspace:*",
    "reactnatively-glass": "workspace:*",
    "reactnatively-hooks": "workspace:*",
    "reactnatively-primitives": "workspace:*",
    "reactnatively-theme": "workspace:*",
    "reactnatively-utils": "workspace:*"
  },
  "peerDependencies": {
    "expo-blur": ">=13.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "react-native-gesture-handler": ">=2.14.0",
    "react-native-reanimated": ">=3.6.0"
  },
  "peerDependenciesMeta": {
    "expo-blur": {
      "optional": true
    },
    "react-native-reanimated": {
      "optional": false
    }
  },
  "devDependencies": {
    "@reactnatively/tsconfig": "workspace:*",
    "@testing-library/react-native": "^12.5.1",
    "jest": "^29.7.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.3"
  },
  "keywords": [
    "react-native",
    "expo",
    "ui",
    "components",
    "design-system",
    "glass",
    "liquid-glass",
    "button",
    "modal",
    "toast",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hakizimana-fred/reactnatively.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
